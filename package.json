{
    "name": "documentic-markdown",
    "displayName": "Documentic Markdown",
    "description": "Export Markdown to Document(PDF, HTML, PNG) with Mermaid and Kroki-based diagram embedding.",
    "version": "0.1.1",
    "publisher": "local",
    "license": "MIT",
    "engines": {
        "vscode": "^1.96.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/OmojiP/documentic-markdown"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:documenticMarkdown.export",
        "onCommand:documenticMarkdown.exportDiagramBlocksPng",
        "onCommand:documenticMarkdown.exportDiagramBlocksSvg"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "documenticMarkdown.export",
                "title": "Documentic: Export Markdown",
                "icon": {
                    "light": "resources/icons/export-light.svg",
                    "dark": "resources/icons/export-dark.svg"
                }
            },
            {
                "command": "documenticMarkdown.exportDiagramBlocksPng",
                "title": "Documentic: Export Diagram Blocks to PNG Folder"
            },
            {
                "command": "documenticMarkdown.exportDiagramBlocksSvg",
                "title": "Documentic: Export Diagram Blocks to SVG Folder"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "documenticMarkdown.export",
                    "when": "resourceLangId == markdown",
                    "group": "navigation@100"
                }
            ]
        },
        "configuration": {
            "title": "%config.title%",
            "properties": {
                "documenticMarkdown.untrustedMarkdownProtection": {
                    "type": "boolean",
                    "default": true,
                    "order": 1,
                    "description": "%config.untrustedMarkdownProtection.description%"
                },
                "documenticMarkdown.includeKroki": {
                    "type": "boolean",
                    "default": true,
                    "order": 2,
                    "description": "%config.includeKroki.description%"
                },
                "documenticMarkdown.pngQuality": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ],
                    "default": "medium",
                    "order": 3,
                    "description": "%config.pngQuality.description%"
                },
                "documenticMarkdown.allowRawHtml": {
                    "type": "boolean",
                    "default": false,
                    "order": 4,
                    "description": "%config.allowRawHtml.description%"
                },
                "documenticMarkdown.openOutputAfterExport": {
                    "type": "boolean",
                    "default": true,
                    "order": 5,
                    "description": "%config.openOutputAfterExport.description%"
                },
                "documenticMarkdown.pdfFormat": {
                    "type": "string",
                    "enum": [
                        "A4",
                        "Letter"
                    ],
                    "default": "A4",
                    "order": 6,
                    "description": "%config.pdfFormat.description%"
                },
                "documenticMarkdown.renderTimeoutMilliSecond": {
                    "type": "number",
                    "default": 10000,
                    "minimum": 1000,
                    "order": 7,
                    "description": "%config.renderTimeoutMilliSecond.description%"
                }
            }
        }
    },
    "scripts": {
        "build": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "fixtures:export": "node scripts/export-test-fixtures.cjs",
        "release:vsix": "node scripts/release-vsix.cjs"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^22.10.2",
        "@types/pngjs": "^6.0.5",
        "@types/vscode": "^1.96.0",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "markdown-it": "^14.1.0",
        "mathjax-full": "^3.2.2",
        "mermaid": "^11.12.0",
        "pngjs": "^7.0.0",
        "puppeteer": "^24.2.0"
    }
}
