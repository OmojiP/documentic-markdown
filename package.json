{
    "name": "documentic-markdown-pdf",
    "displayName": "Documentic Markdown PDF",
    "description": "Export Markdown to PDF with Mermaid and Kroki-based diagram embedding.",
    "version": "0.0.1",
    "publisher": "local",
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:documenticMarkdown.export",
        "onCommand:documenticMarkdown.exportToPdf"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "documenticMarkdown.export",
                "title": "Documentic: Export Markdown"
            },
            {
                "command": "documenticMarkdown.exportToPdf",
                "title": "Documentic: Export Markdown to PDF"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "documenticMarkdown.export",
                    "when": "resourceLangId == markdown",
                    "group": "navigation@100"
                }
            ]
        },
        "configuration": {
            "title": "Documentic Markdown PDF",
            "properties": {
                "documenticMarkdown.includeUml": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable PlantUML/UML fenced block conversion to SVG via Kroki."
                },
                "documenticMarkdown.includeKroki": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable non-UML Kroki-supported fenced block conversion to SVG."
                },
                "documenticMarkdown.pdfFormat": {
                    "type": "string",
                    "enum": [
                        "A4",
                        "Letter"
                    ],
                    "default": "A4",
                    "description": "PDF page format."
                }
            }
        }
    },
    "scripts": {
        "build": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^22.10.2",
        "@types/vscode": "^1.96.0",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "markdown-it": "^14.1.0",
        "puppeteer": "^24.2.0"
    }
}